# ─────────────────────────────────────────────────────────────────────────────
# luxeStay-frontend-admin — variables de entorno
#
# Angular no lee .env en tiempo de ejecución.
# Estas variables se usan como build-args del Dockerfile o se inyectan
# en environment.ts mediante configure-env.js durante el build de Docker.
# Para desarrollo local editar directamente:
#   src/environments/environment.ts
# ─────────────────────────────────────────────────────────────────────────────

# URL base de la API del backend
# Local:
ANGULAR_API_URL=http://localhost:8080/api/v1
# Producción (reemplazar con URL real):
# ANGULAR_API_URL=https://tu-backend.onrender.com/api/v1
